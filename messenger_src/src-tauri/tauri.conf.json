{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "messenger-app",
  "version": "0.1.0",
  "identifier": "kz.yerlan.messenger",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Messenger",
        "width": 400,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
